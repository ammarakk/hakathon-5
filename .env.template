# Nur Scents Customer Success Agent - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nur_scents_db
POSTGRES_USER=nur_scents_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_SSL_MODE=prefer

# ============================================
# KAFKA CONFIGURATION
# ============================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=nur_scents_agent_group
KAFKA_AUTO_OFFSET_RESET=earliest

# ============================================
# AI/AGENT CONFIGURATION
# ============================================
# Gemini 2.0 Flash API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=1024

# ============================================
# TWILIO WHATSAPP CONFIGURATION
# ============================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_PHONE_NUMBER=+1254XXXXXXX

# ============================================
# GMAIL API CONFIGURATION
# ============================================
GMAIL_CREDENTIALS_PATH=/path/to/credentials.json
GMAIL_TOKEN_PATH=/path/to/token.json
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.modify
GMAIL_WATCH_LABEL=INBOX

# ============================================
# FASTAPI CONFIGURATION
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
DEBUG=false
SECRET_KEY=your_secret_key_for_jwt
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGINS=["http://localhost:3000", "https://nurscents.pk"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ============================================
# NEXT.JS CONFIGURATION
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Nur Scents
NEXT_PUBLIC_SITE_DESCRIPTION=Premium Attars & Fragrances from Karachi

# ============================================
# OWNER CONFIGURATION
# ============================================
OWNER_NAME=Ammar
OWNER_PHONE=+92XXXXXXXXXX
OWNER_EMAIL=ammar@nurscents.pk
OWNER_TIMEZONE=Asia/Karachi

# ============================================
# BUSINESS CONFIGURATION
# ============================================
BUSINESS_NAME=Nur Scents
BUSINESS_CURRENCY=PKR
BUSINESS_LANGUAGE=ur,en
BUSINESS_CITY=Karachi
BUSINESS_COUNTRY=Pakistan

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=./logs/app.log
LOG_ROTATION=100MB
LOG_RETENTION=30

# ============================================
# MONITORING CONFIGURATION
# ============================================
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30

# ============================================
# RATE LIMITING
# ============================================
MAX_REQUESTS_PER_MINUTE=60
MAX_ORDERS_PER_HOUR=10
SPAM_DETECTION_ENABLED=true

# ============================================
# K3D KUBERNETES CONFIGURATION
# ============================================
K3D_CLUSTER_NAME=nur-scents-cluster
K3D_API_PORT=30080
K3D_FRONTEND_PORT=30081

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=development
DEPLOYMENT=local
